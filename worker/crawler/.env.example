DATABASE_TYPE=postgres
POSTGRES_DATABASE_URL=postgres://postgres:postgres_password@127.0.0.1:3215/station_db
MYSQL_DATABASE_URL=mysql://station_user:station_password@127.0.0.1:3214/station_db
SQLITE_DATABASE_URL=sqlite://storage/sqlite/stations.sqlite3

REDIS_URL=redis://127.0.0.1:3216
UPDATE_INTERVAL_SECONDS=86400
TEMP_ASSET_DIR=worker/crawler/temp_assets
JOB_LOCK_DIR=storage/locks

# Optional override. Defaults are DB-specific:
# - postgres: write=1000, close=1000
# - mysql: write=200, close=1000
# - sqlite: write=76, close=998
# INGEST_WRITE_CHUNK_SIZE=76
# INGEST_CLOSE_CHUNK_SIZE=998

# Empty uses the currently pinned official N02 snapshot URL in code.
# Set this to an https URL or file://... ZIP when you want to pin or test another release.
SOURCE_SNAPSHOT_URL=

# Set this only when you intentionally want local fixture / file ingest.
# ALLOW_LOCAL_SOURCE_SNAPSHOT=true
