DATABASE_TYPE=postgres
POSTGRES_DATABASE_URL=postgres://postgres:postgres_password@127.0.0.1:3215/station_db
MYSQL_DATABASE_URL=mysql://station_user:station_password@127.0.0.1:3214/station_db

# export-sqlite writes the read-only artifact here
SQLITE_DATABASE_URL=sqlite://storage/sqlite/stations.sqlite3

# one-shot jobs keep their advisory lock files here
JOB_LOCK_DIR=storage/locks

# ingest-n02 stores downloaded ZIP files here before parsing
TEMP_ASSET_DIR=worker/crawler/temp_assets

# Empty uses the currently pinned official N02 snapshot URL in code.
# Set this to an https URL or file://... ZIP when pinning a release or testing locally.
SOURCE_SNAPSHOT_URL=
