DATABASE_TYPE=postgres
POSTGRES_DATABASE_URL=postgres://postgres:postgres_password@127.0.0.1:5432/station_db
MYSQL_DATABASE_URL=mysql://station_user:station_password@127.0.0.1:3306/station_db
SQLITE_DATABASE_URL=sqlite:///opt/station_converter_ja/storage/sqlite/stations.sqlite3

REDIS_URL=
READY_REQUIRE_CACHE=false
BIND_ADDR=0.0.0.0:3212
TEMP_ASSET_DIR=/opt/station_converter_ja/worker/crawler/temp_assets
JOB_LOCK_DIR=/run/station-converter-ja

# Leave empty for the pinned official upstream snapshot.
# Set to an alternate https URL or file://... ZIP when pinning a local test snapshot.
SOURCE_SNAPSHOT_URL=

# Leave empty for ingest only. Set to --export-sqlite to chain artifact export.
STATION_INGEST_ARGS=
